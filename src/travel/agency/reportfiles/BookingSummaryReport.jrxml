<jasperReport name="BookingSummaryReport" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="214d4a7d-1195-4d69-9090-6560be871a23">
	<query language="sql"><![CDATA[SELECT b.booking_id, c.full_name, p.package_name, p.destination,
       b.travel_date, b.no_of_travelers, b.total_amount, b.status
FROM booking b
JOIN customer c ON b.customer_id = c.customer_id
JOIN trip_package p ON b.package_id = p.package_id
ORDER BY b.travel_date]]></query>
	<field name="booking_id" class="java.lang.Integer"/>
	<field name="full_name" class="java.lang.String"/>
	<field name="package_name" class="java.lang.String"/>
	<field name="destination" class="java.lang.String"/>
	<field name="travel_date" class="java.sql.Date"/>
	<field name="no_of_travelers" class="java.lang.Integer"/>
	<field name="total_amount" class="java.math.BigDecimal"/>
	<field name="status" class="java.lang.String"/>
